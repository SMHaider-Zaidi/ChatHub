<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ChatHub</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <!-- Header -->
    <header class="flex justify-between items-center p-4 bg-white shadow">
        <div class="flex items-center space-x-2">
            <div class="w-8 h-8 bg-blue-500 rounded-full"></div>
            <h1 class="text-xl font-bold">ChatHub</h1>
        </div>


        </div>
    </header>

    <!-- Main Box -->
    <main class="flex flex-col items-center justify-center min-h-screen px-4">
        
        <div class="bg-white shadow-lg rounded-lg p-8 w-full max-w-md text-center">
            
            <h2 class="text-2xl font-bold mb-2">Welcome to ChatHub</h2>

            <p class="text-gray-600 mb-6">
                Join the real-time chat and connect with your friends instantly.
            </p>

            <!-- Buttons -->
            <div class="flex flex-col gap-3">

                <a href="/login"
                   class="w-full bg-blue-500 text-white py-2 rounded hover:bg-blue-600">
                   Login to Chat
                </a>

                <a href="/register"
                   class="w-full bg-gray-800 text-white py-2 rounded hover:bg-gray-900">
                   Create Account
                </a>

            </div>
        </div>

        <!-- About Section -->
        <section class="mt-8 max-w-md text-center text-gray-700">
            <h3 class="text-lg font-semibold mb-2">About ChatHub</h3>
            <p>
               ChatHub is a simple real-time chat application where you can connect with people instantly.
    Create an account, log in, and start chatting in seconds.
            </p>
        </section>

    </main>

</body>
</html>